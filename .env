# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://Mahi123:Mahesh12@cluster0.jf4gnyu.mongodb.net/wayfarer?retryWrites=true&w=majority

# JWT signing secret - use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google AI Studio key for Gemini. If left blank, the API automatically
# falls back to a deterministic local itinerary generator so the app
# still works end-to-end for demos without billing/keys.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=https://travel-frontend-ten-steel.vercel.app/
